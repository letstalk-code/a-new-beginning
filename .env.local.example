# GHL inbound webhook URL — used by app/api/lead/route.ts to forward
# website lead submissions to GoHighLevel.
#
# Get this URL from inside the A New Beginning sub-account:
#   Automation → Workflows → Create Workflow → Start from Scratch
#   Add Trigger → "Inbound Webhook" → save → copy the generated webhook URL.
#
# Then create .env.local (gitignored) and set the line below.
GHL_LEAD_WEBHOOK_URL=
