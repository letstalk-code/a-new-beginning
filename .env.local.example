# GHL Private Integration Token (PIT) and Location ID — used by
# app/api/lead/route.ts to create contacts directly in GoHighLevel
# via the Contacts API (no webhook in between).
#
# Generate the PIT in the A New Beginning sub-account:
#   Settings → Private Integrations → Create new integration
#   Scopes required: contacts.readonly + contacts.write
#   Copy the pit-... token. Token is shown ONCE on creation.
#
# Location ID is shown at: Settings → Business Profile → "Location ID"
GHL_PIT=
GHL_LOCATION_ID=
